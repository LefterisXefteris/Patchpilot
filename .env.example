NODE_ENV=development
BTS_LOG_LEVEL=info
BTS_DRY_RUN=true

SENTRY_AUTH_TOKEN=sntrys_PLACEHOLDER
SENTRY_ORG_SLUG=your-sentry-org
SENTRY_PROJECT_SLUG=your-sentry-project
SENTRY_ENVIRONMENT=production
SENTRY_REGION_URL=https://sentry.io
SENTRY_WEBHOOK_SECRET=placeholder-webhook-secret

GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nPLACEHOLDER\n-----END PRIVATE KEY-----"
GITHUB_INSTALLATION_ID=12345678
GITHUB_OWNER=your-org
GITHUB_REPO=your-repo
GITHUB_TARGET_INSTALLATION_ID=
GITHUB_TARGET_OWNER=broken-app-org-or-user
GITHUB_TARGET_REPO=broken-app-repo
GITHUB_WEBHOOK_SECRET=placeholder-webhook-secret
GITHUB_BASE_BRANCH=main

VERCEL_TOKEN=vercel_PLACEHOLDER
VERCEL_TEAM_ID=team_PLACEHOLDER
VERCEL_TEAM_SLUG=your-team
VERCEL_PROJECT_ID=prj_PLACEHOLDER
VERCEL_PROJECT_NAME=your-project

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
BTS_REPAIR_PROVIDER=claude

AUTOPILOT_ENABLED=false
AUTOPILOT_DRY_RUN=true
AUTOPILOT_CONFIDENCE_THRESHOLD=0.85
AUTOPILOT_MAX_FILES_CHANGED=5
AUTOPILOT_MAX_LINES_CHANGED=250
AUTOPILOT_ALLOWED_ACTIONS=update_issue,trigger_claude
AUTOPILOT_PROTECTED_PATHS=.github/workflows/**,infra/**,prisma/**
AUTOPILOT_ALLOW_MERGE=false
AUTOPILOT_ALLOW_DEPLOY=false
AUTOPILOT_ALLOW_ROLLBACK=false
AUTOPILOT_ALLOW_RECOVERY_HOOK=false
AUTOPILOT_EMERGENCY_STOP=false

# Verification of recovery (used by agent:recover)
BTS_TARGET_PRODUCTION_URL=https://your-target.example.com
BTS_TARGET_HEALTH_CHECK_PATH=/
BTS_TARGET_HEALTH_CHECK_STATUS=200
BTS_TARGET_HEALTH_CHECK_TIMEOUT_MS=10000
BTS_TARGET_VERCEL_PROJECT_ID=
BTS_TARGET_VERCEL_TEAM_ID=
BTS_TARGET_SENTRY_PROJECT_SLUG=

# Retry / escalate policy (used by agent:recover)
BTS_RECOVERY_MAX_ATTEMPTS=3
BTS_RECOVERY_PARTIAL_TOLERANCE=2
BTS_RECOVERY_MIN_DEPLOY_AGE_SECONDS=60
BTS_RECOVERY_NEEDS_HUMAN_LABEL=needs-human
BTS_RECOVERY_RESOLVED_LABEL=auto-recovery-resolved

# Sentry performance bottleneck intake (used by agent:performance)
PERF_ENABLED=false
PERF_MIN_SAMPLE_COUNT=20
PERF_P95_THRESHOLD_MS=1000
PERF_REGRESSION_RATIO=1.5
PERF_ALLOWED_OPS=http.server,db,http.client,navigation

# Optional PostHog product impact context
POSTHOG_ENABLED=false
POSTHOG_PERSONAL_API_KEY=
POSTHOG_PROJECT_ID=
POSTHOG_HOST=https://us.posthog.com
POSTHOG_IMPACT_EVENTS=signup_completed,checkout_completed,purchase_completed
POSTHOG_IMPACT_WINDOW_HOURS=24
POSTHOG_IMPACT_BASELINE_HOURS=24
