{
  "name": "patchpilot",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run",
    "validate:config": "tsx src/index.ts validate-config",
    "agent:sync": "tsx src/index.ts agent:sync",
    "agent:performance": "tsx src/index.ts agent:performance",
    "agent:watch": "tsx src/index.ts agent:watch",
    "agent:run": "tsx src/index.ts agent:run",
    "agent:recover": "tsx src/index.ts agent:recover",
    "eval": "tsx src/index.ts eval",
    "ui": "next dev --hostname 127.0.0.1 --port 4317",
    "ui:build": "next build",
    "ui:start": "next start --hostname 127.0.0.1 --port 4317",
    "ui:legacy": "tsx src/ui/server.ts",
    "show:claude-workflow": "tsx src/scripts/show-claude-workflow.ts",
    "show:codex-workflow": "tsx src/scripts/show-codex-workflow.ts"
  },
  "dependencies": {
    "@ast-grep/napi": "^0.42.1",
    "@octokit/auth-app": "^7.0.0",
    "@octokit/rest": "^21.0.2",
    "@tailwindcss/postcss": "^4.3.0",
    "@vercel/sdk": "^1.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.16.0",
    "next": "^16.2.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.7",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.18.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^2.1.8"
  }
}
